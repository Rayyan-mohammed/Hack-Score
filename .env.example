# Supabase — copy this file to .env.local and fill in your project values.
# Project Settings -> API keys in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Secret key — server-side only, never exposed to the browser.
# Used by admin actions (creating judge accounts, bulk imports).
SUPABASE_SECRET_KEY=sb_secret_xxx

# Absolute site origin, used to build links inside result emails.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Email (SMTP) — server-side only. For Gmail, SMTP_PASS MUST be a 16-char
# App Password (enable 2-Step Verification first); the account password is
# rejected by Gmail SMTP. Leave unset to disable email (nothing 500s).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM_NAME=HackScore
